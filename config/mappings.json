{
  "appProfiles": {
    "company.thebrowser.Browser": "arc",
    "com.mitchellh.ghostty": "ghostty",
    "net.whatsapp.WhatsApp": "whatsapp"
  },
  "alwaysOn": {
    "analog": {
      "leftStickVerticalScroll": {
        "enabled": true,
        "deadzone": 0.20,
        "intervalMs": 50,
        "minLinesPerTick": 1,
        "maxLinesPerTick": 8,
        "responseExponent": 2.6,
        "invert": false
      }
    },
    "mappings": {
      "rightTrigger": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 48,
          "modifiers": [
            "control"
          ],
          "description": "Send Control-Tab"
        }
      },
      "leftTrigger": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 48,
          "modifiers": [
            "shift",
            "control"
          ],
          "description": "Send Shift-Control-Tab"
        }
      },
      "x": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 48,
          "modifiers": [],
          "description": "Send Tab (L2 + X behaves like Cmd+Tab)"
        }
      },
      "a": {
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 49,
          "modifiers": [
            "option"
          ],
          "description": "Send Option-Space for Handy transcription"
        }
      },
      "b": {
        "debounceMs": 120,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 36,
          "modifiers": [],
          "description": "Send Enter everywhere"
        }
      },
      "y": {
        "debounceMs": 120,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 53,
          "modifiers": [],
          "description": "Send Escape everywhere"
        }
      },
      "dpadUp": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 8,
          "modifiers": [
            "control"
          ],
          "description": "Send Control-C"
        }
      },
      "dpadDown": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 125,
          "modifiers": [],
          "description": "Send Down Arrow"
        }
      },
      "dpadLeft": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "focusDisplay",
          "direction": "left",
          "description": "Move cursor focus to the display on the left"
        }
      },
      "dpadRight": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "focusDisplay",
          "direction": "right",
          "description": "Move cursor focus to the display on the right"
        }
      },
      "leftShoulder": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 123,
          "modifiers": [
            "control",
            "function"
          ],
          "description": "Move to the previous macOS space/display"
        }
      },
      "rightShoulder": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 124,
          "modifiers": [
            "control",
            "function"
          ],
          "description": "Move to the next macOS space/display"
        }
      }
    }
  },
  "profiles": {
    "arc": {
      "enabled": true,
      "analog": {
        "leftStickPointer": {
          "enabled": true,
          "deadzone": 0.24,
          "intervalMs": 18,
          "minPixelsPerTick": 2,
          "maxPixelsPerTick": 24,
          "responseExponent": 2.2,
          "invertX": false,
          "invertY": true
        }
      },
      "mappings": {
        "leftTrigger": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 48,
            "modifiers": [
              "shift",
              "control"
            ],
            "description": "Send Shift-Control-Tab"
          }
        },
        "rightTrigger": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 48,
            "modifiers": [
              "control"
            ],
            "description": "Send Control-Tab"
          }
        },
        "b": {
          "debounceMs": 80,
          "edgeTrigger": true,
          "action": {
            "type": "mouseClick",
            "mouseButton": "left",
            "description": "Click the current cursor location"
          }
        },
        "x": {
          "debounceMs": 120,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 15,
            "modifiers": [
              "command"
            ],
            "description": "Refresh the current Arc page"
          }
        },
        "dpadUp": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 13,
            "modifiers": [
              "command"
            ],
            "description": "Close the current Arc tab"
          }
        },
        "thumbsticksBoth": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 17,
            "modifiers": [
              "command"
            ],
            "description": "Open a new Arc tab with search focused"
          }
        }
      }
    },
    "ghostty": {
      "enabled": true,
      "analog": {
        "leftStickVerticalActions": {
          "enabled": true,
          "deadzone": 0.58,
          "repeatIntervalMs": 140,
          "edgeTrigger": false,
          "upAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:up",
            "description": "Focus the split above"
          },
          "downAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:down",
            "description": "Focus the split below"
          }
        },
        "leftStickHorizontalActions": {
          "enabled": true,
          "deadzone": 0.58,
          "repeatIntervalMs": 140,
          "edgeTrigger": false,
          "leftAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:left",
            "description": "Focus the split to the left"
          },
          "rightAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:right",
            "description": "Focus the split to the right"
          }
        },
        "rightStickVerticalActions": {
          "enabled": true,
          "deadzone": 0.58,
          "repeatIntervalMs": 140,
          "edgeTrigger": false,
          "upAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "resize_split:up,100",
            "description": "Resize split upward"
          },
          "downAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "resize_split:down,100",
            "description": "Resize split downward"
          }
        },
        "rightStickHorizontalActions": {
          "enabled": true,
          "deadzone": 0.58,
          "repeatIntervalMs": 140,
          "edgeTrigger": false,
          "leftAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "resize_split:left,100",
            "description": "Resize split to the left"
          },
          "rightAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "resize_split:right,100",
            "description": "Resize split to the right"
          }
        }
      },
      "mappings": {
        "menu": {
          "debounceMs": 250,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "close_surface",
            "description": "Close focused split surface via Ghostty native action"
          }
        },
        "options": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "text",
            "text": "co",
            "delayMs": 80,
            "pressEnter": true,
            "description": "Launch Codex via the Ghostty co alias"
          }
        },
        "share": {
          "debounceMs": 500,
          "edgeTrigger": true,
          "action": {
            "type": "shell",
            "command": "$HOME/.agents/codex/scripts/open-ghostty-codex-picker-tab.sh",
            "description": "Capture button: open a new Ghostty picker tab via the shared Codex helper"
          }
        },
        "rightThumbstickButton": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "new_split:down",
            "description": "Split down via Ghostty native action"
          }
        },
        "leftThumbstickButton": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "new_split:right",
            "description": "Split right via Ghostty native action"
          }
        },
        "thumbsticksBoth": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "new_tab",
            "description": "Open a new Ghostty tab when both thumbstick buttons are pressed together"
          }
        },
        "dpadUp": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 8,
            "modifiers": [
              "control"
            ],
            "description": "Send Control-C"
          }
        },
        "dpadDown": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 121,
            "modifiers": [],
            "description": "Page down through scrollback"
          }
        },
        "dpadLeft": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "focusDisplay",
            "direction": "left",
            "description": "Move cursor focus to the display on the left"
          }
        },
        "dpadRight": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "focusDisplay",
            "direction": "right",
            "description": "Move cursor focus to the display on the right"
          }
        }
      }
    },
    "whatsapp": {
      "enabled": true,
      "mappings": {
        "y": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "preKeyCode": 0,
            "preModifiers": [
              "command"
            ],
            "preDelayMs": 40,
            "keyCode": 51,
            "modifiers": [],
            "description": "Clear the WhatsApp chat input"
          }
        },
        "x": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 48,
            "modifiers": [],
            "description": "Move focus into the active WhatsApp chat"
          }
        },
        "dpadUp": {
          "debounceMs": 140,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 33,
            "modifiers": [
              "command",
              "shift"
            ],
            "description": "Move to the previous WhatsApp chat"
          }
        },
        "dpadDown": {
          "debounceMs": 140,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 30,
            "modifiers": [
              "command",
              "shift"
            ],
            "description": "Move to the next WhatsApp chat"
          }
        }
      }
    }
  },
  "safety": {
    "dryRun": true,
    "emergencyToggleButton": null
  }
}
