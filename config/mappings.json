{
  "appProfiles": {
    "com.mitchellh.ghostty": "ghostty"
  },
  "alwaysOn": {
    "analog": {
      "leftStickVerticalScroll": {
        "enabled": true,
        "deadzone": 0.20,
        "intervalMs": 50,
        "minLinesPerTick": 1,
        "maxLinesPerTick": 8,
        "responseExponent": 2.6,
        "invert": false
      }
    },
    "mappings": {
      "rightTrigger": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 48,
          "modifiers": [
            "control"
          ],
          "description": "Send Control-Tab"
        }
      },
      "leftTrigger": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 48,
          "modifiers": [
            "shift",
            "control"
          ],
          "description": "Send Shift-Control-Tab"
        }
      },
      "x": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 48,
          "modifiers": [],
          "description": "Send Tab (L2 + X behaves like Cmd+Tab)"
        }
      },
      "y": {
        "debounceMs": 120,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 53,
          "modifiers": [],
          "description": "Send Escape everywhere"
        }
      },
      "dpadUp": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 126,
          "modifiers": [],
          "description": "Send Up Arrow"
        }
      },
      "dpadDown": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 125,
          "modifiers": [],
          "description": "Send Down Arrow"
        }
      },
      "dpadLeft": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 123,
          "modifiers": [],
          "description": "Send Left Arrow"
        }
      },
      "dpadRight": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 124,
          "modifiers": [],
          "description": "Send Right Arrow"
        }
      },
      "leftShoulder": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "applescript",
          "script": "tell application \"System Events\" to key code 123 using {control down}",
          "description": "Move to the previous macOS space/display via System Events"
        }
      },
      "rightShoulder": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "applescript",
          "script": "tell application \"System Events\" to key code 124 using {control down}",
          "description": "Move to the next macOS space/display via System Events"
        }
      }
    }
  },
  "profiles": {
    "ghostty": {
      "enabled": true,
      "analog": {
        "rightStickVerticalActions": {
          "enabled": true,
          "deadzone": 0.58,
          "repeatIntervalMs": 140,
          "edgeTrigger": false,
          "upAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "resize_split:up,100",
            "description": "Resize split upward"
          },
          "downAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "resize_split:down,100",
            "description": "Resize split downward"
          }
        },
        "rightStickHorizontalActions": {
          "enabled": true,
          "deadzone": 0.58,
          "repeatIntervalMs": 140,
          "edgeTrigger": false,
          "leftAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "resize_split:left,100",
            "description": "Resize split to the left"
          },
          "rightAction": {
            "type": "ghosttyAction",
            "ghosttyAction": "resize_split:right,100",
            "description": "Resize split to the right"
          }
        }
      },
      "mappings": {
        "menu": {
          "debounceMs": 250,
          "edgeTrigger": true,
          "action": {
            "type": "text",
            "text": "co",
            "delayMs": 80,
            "pressEnter": true,
            "description": "Launch Codex via the Ghostty co alias"
          }
        },
        "options": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "close_surface",
            "description": "Close focused split surface via Ghostty native action"
          }
        },
        "share": {
          "debounceMs": 500,
          "edgeTrigger": true,
          "action": {
            "type": "shell",
            "command": "$HOME/.agents/codex/scripts/open-ghostty-codex-picker-tab.sh",
            "description": "Capture button: open a new Ghostty picker tab via the shared Codex helper"
          }
        },
        "rightThumbstickButton": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "new_split:right",
            "description": "Split right via Ghostty native action"
          }
        },
        "leftThumbstickButton": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "new_split:down",
            "description": "Split down via Ghostty native action"
          }
        },
        "a": {
          "edgeTrigger": true,
          "action": {
            "type": "holdKeystroke",
            "keyCode": 49,
            "modifiers": [],
            "description": "Hold Space for dictation"
          }
        },
        "b": {
          "debounceMs": 120,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 36,
            "modifiers": [],
            "description": "Send Enter"
          }
        },
        "dpadUp": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:up",
            "description": "Focus the split above"
          }
        },
        "dpadDown": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:down",
            "description": "Focus the split below"
          }
        },
        "dpadLeft": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:left",
            "description": "Focus the split to the left"
          }
        },
        "dpadRight": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:right",
            "description": "Focus the split to the right"
          }
        }
      }
    }
  },
  "safety": {
    "dryRun": true,
    "emergencyToggleButton": null
  }
}
